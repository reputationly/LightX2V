{
    "infer_steps": 4,
    "target_fps": 16,
    "video_duration": 360,
    "audio_sr": 16000,
    "target_video_length": 81,
    "target_height": 832,
    "target_width": 480,
    "ref_state": 1,
    "self_attn_1_type": "sage_attn2",
    "cross_attn_1_type": "sage_attn2",
    "cross_attn_2_type": "sage_attn2",
    "sample_guide_scale": 1.0,
    "sample_shift": 5.0,
    "enable_cfg": false,
    "cpu_offload": true,
    "offload_granularity": "block",
    "use_31_block": true,
    "dit_quantized": true,
    "dit_quantized_ckpt": "/models/seko-distill-ar/converted_fp8.safetensors",
    "dit_quant_scheme": "fp8-sgl",
    "adapter_quantized": true,
    "adapter_quant_scheme": "fp8",
    "adapter_model_path": "/models/seko-distill-ar/-audio_adapter_fp8.pt",
    "audio_feature_dim": 1024,
    "audio_projection_dim": 1024,
    "audio_num_tokens": 32,
    "projection_transformer_layers": 4,
    "audio_window": 1.0,
    "look_ahead": 0.0,
    "audio_feat_window_neighbor_frame": 0,
    "audio_feat_fps": 50,
    "ar_config": {
        "num_frame_per_chunk": 1,
        "step_kv_cache": true,
        "sink_size": 2,
        "local_attn_size": 21,
        "kv_offload": false,
        "async_vae_decode": true,
        "kv_quant": {
            "quant_scheme": "longlive_fp4",
            "scale_rule": "mse",
            "backend": "triton"
        }
    }
}
